# === API Keys ===
SHODAN_API_KEY=your_shodan_key_here
OPENAI_API_KEY=your_openai_key_here

# === Tool Paths ===
NMAP_PATH=/usr/bin/nmap
SQLMAP_PATH=/usr/share/sqlmap/sqlmap.py
WPSCAN_PATH=/usr/bin/wpscan
NIKTO_PATH=/usr/bin/nikto
DIRSEARCH_PATH=/opt/dirsearch/dirsearch.py
BURP_PATH=/opt/BurpSuite/BurpSuite.jar
ONIONSHARE_PATH=/usr/bin/onionshare

# === Logging & UI ===
LOG_LEVEL=DEBUG
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=5050

# === Remote Features ===
TAILSCALE_ENABLED=false
TELEGRAM_TOKEN=your_telegram_bot_token
DISCORD_HOOK=https://discord.com/api/webhooks/your_id

# === Security Options ===
ENABLE_BIOMETRICS=false

GITHUB_API_TOKEN = "your_github_token"
TELEGRAM_BOT_TOKEN = "your_bot_token"
TELEGRAM_CHAT_ID = "your_chat_id"
DISCORD_WEBHOOK_URL = "https://discord.com/api/webhooks/...."
USE_TOR_PROXY = True  # enable .onion routing

SHODAN_API_KEY = "your_shodan_key"
HUNTER_API_KEY = "your_hunter_key"
HIBP_API_KEY = "your_hibp_key"